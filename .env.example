# Make a copy of this to set environment variables for local development
# cp .env.example .env

# TODO: Fill in auth related env vars
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# TODO: Update with the MLflow experiment you want to log traces and models to
MLFLOW_EXPERIMENT_ID=

# TODO: Genie space UUIDs (from the Genie space URL).
GENIE_FINANCE_SPACE_ID=
GENIE_SALES_SPACE_ID=

# Chat model serving endpoint used by all supervisors.
LLM_ENDPOINT=databricks-gpt-5-2

# Only used by the Model Serving deployment (`uv run deploy-serving`).
# UC catalog/schema/model name to register the supervisor under.
# Schema is auto-created if missing.
SERVING_UC_CATALOG=main
SERVING_UC_SCHEMA=supervisor_example_obo
SERVING_UC_MODEL_NAME=supervisor
SERVING_ENDPOINT_NAME=supervisor-example-obo-serving

# Local-dev only: when the x-forwarded-access-token header is absent (i.e.
# you're not running inside a Databricks App), allow the user WorkspaceClient
# to fall back to your CLI profile. MUST be unset in eval / prod.
OBO_FALLBACK_TO_DEFAULT=1

CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
